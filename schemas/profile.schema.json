{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/th-chromassist/profile.schema.json",
  "title": "TH Chromassist profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "vision", "game", "palette", "fairness", "created_at_utc", "algorithm_version"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "vision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "severity", "source", "confidence", "user_overrode_result"],
      "properties": {
        "type": { "enum": ["normal", "protan", "deutan", "tritan", "unknown", "manual"] },
        "severity": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "enum": ["preset", "screening", "manual"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "user_overrode_result": { "type": "boolean" }
      }
    },
    "display_environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "night_mode_disabled": { "type": ["boolean", "null"] },
        "unusual_filters_disabled": { "type": ["boolean", "null"] },
        "standard_or_srgb_mode": { "type": ["boolean", "null"] }
      }
    },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "executable_sha256", "data_archive_sha256"],
      "properties": {
        "id": { "const": "th18" },
        "version": { "type": "string" },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "data_archive_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": true,
      "required": ["preset_id", "user_modified", "files"],
      "properties": {
        "preset_id": { "type": "string" },
        "user_modified": { "type": "boolean" },
        "files": { "type": "array", "items": { "type": "object" } }
      }
    },
    "fairness": { "type": "object", "additionalProperties": true },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "algorithm_version": { "type": "string" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
  }
}
